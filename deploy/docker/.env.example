# Copy to .env and replace every change-me value before starting the stack.
#   cp .env.example .env

# Public HTTP port for the API (serves REST API and built SPA).
APP_PORT=8000

# PostgreSQL
POSTGRES_USER=cogito
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=cogito_review

# Database pool sizing (API + worker)
DB_POOL_MIN_SIZE=2
DB_POOL_MAX_SIZE=10

# Published GHCR images. Pin a semver tag or digest in production instead of latest.
COGITO_REVIEW_IMAGE=ghcr.io/cogitoforge-ai/cogito-review:latest
COGITO_REVIEW_AGENT_IMAGE=ghcr.io/cogitoforge-ai/cogito-review-agent:latest

# Per-review agent container limits when the worker spawns reviews.
COGITO_REVIEW_AGENT_MEM_LIMIT=2g
COGITO_REVIEW_AGENT_CPUS=2.0

# Celery worker concurrency (review jobs processed in parallel).
WORKER_CONCURRENCY=2

# Redis memory cap inside the container.
REDIS_MAXMEMORY=256mb

# Agent HTTP callback (HMAC). Must match the internal api service URL in Compose.
COGITO_REVIEW_AGENT_CALLBACK_SECRET=change-me-callback-secret

# Auth and application secrets (required when COGITO_REVIEW_AUTH_ENABLED=true).
COGITO_REVIEW_AUTH_ENABLED=true
COGITO_REVIEW_SECRETS_ENCRYPTION_KEY=change-me-encryption-key-32chars-min
COGITO_REVIEW_SESSION_SECRET=change-me-session-secret
COGITO_REVIEW_SESSION_TTL_SECONDS=86400

# First org admin created on startup when the database is empty.
COGITO_REVIEW_BOOTSTRAP_ORG_ADMIN_EMAIL=admin@example.com

# Public URL users open in the browser (OIDC/SAML redirects and session cookies).
COGITO_REVIEW_FRONTEND_URL=http://localhost:8000

# Application logging level for spawned review agents.
COGITO_REVIEW_OPENCODE_LOG_LEVEL=INFO

# Prometheus metrics (internal port 9090; not published to the host).
COGITO_REVIEW_METRICS_ENABLED=true

# --- Monitoring profile (docker compose --profile monitoring up -d) ---

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me-grafana-password
GRAFANA_PORT=3000
GRAFANA_ROOT_URL=http://localhost:3000

PROMETHEUS_PORT=9091
PROMETHEUS_RETENTION=15d

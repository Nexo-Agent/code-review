{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "coreview": {
      "type": "local",
      "command": ["coreview-agent", "serve", "--transport", "stdio"],
      "enabled": true
    }
  },
  "skills": {
    "paths": ["/opencode/skills"]
  },
  "tools": {
    "question": false
  },
  "permission": {
    "read": "allow",
    "grep": "allow",
    "glob": "allow",
    "list": "allow",
    "bash": {
      "*": "allow"
    },
    "task": "allow",
    "todowrite": "allow",
    "skill": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "lsp": "allow",
    "external_directory": "deny",
    "question": "deny",
    "doom_loop": "deny",
    "plan_enter": "deny",
    "plan_exit": "deny",
    "ask_exit": "deny",
    "terminal_start": "deny",
    "terminal_stop": "deny",
    "pty_start": "deny",
    "pty_exec": "deny",
    "pty_stop": "deny"
  },
  "provider": {},
  "agent": {
    "code-reviewer": {
      "description": "Reviews PR for bugs, security, and maintainability",
      "mode": "primary",
      "tools": {
        "coreview-git_fetch_pr_context": true,
        "coreview-ci_get_summary": true,
        "question": false
      },
      "permission": {
        "edit": "deny",
        "write": "deny",
        "read": "allow",
        "grep": "allow",
        "glob": "allow",
        "list": "allow",
        "bash": {
          "*": "allow"
        },
        "task": "allow",
        "todowrite": "allow",
        "skill": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "external_directory": "deny",
        "question": "deny",
        "doom_loop": "deny",
        "plan_enter": "deny",
        "plan_exit": "deny",
        "ask_exit": "deny",
        "terminal_start": "deny",
        "terminal_stop": "deny",
        "pty_start": "deny",
        "pty_exec": "deny",
        "pty_stop": "deny"
      },
      "prompt": "You are a code reviewer. Use MCP tools to gather context before reviewing: call coreview-git_fetch_pr_context and coreview-ci_get_summary with the repository and PR details from the prompt. Analyze the cloned workspace at the session directory. Use bash to run lint, typecheck, and unit tests when the project defines them. Trace blast radius beyond the diff with grep and cross-layer checks. Do not modify files or post remote comments via MCP. Return findings as JSON matching the outputFormat schema in your final response. Focus on bugs, security issues, performance problems, missing tests, and validation failures.",
      "model": "openai-compat/gpt-4o"
    }
  }
}

# Nexo Co-Review (codename: nexo-coreview, env: NEXO_COREVIEW_*) — infrastructure only
# Git repo, webhook secret, GitHub token, and LLM settings are managed via
# the Settings UI (GET/PUT /api/v1/settings/integration).
NEXO_COREVIEW_CELERY_BROKER_URL=redis://redis:6379/0
NEXO_COREVIEW_RUNTIME_PROVIDER=docker
NEXO_COREVIEW_WORKSPACE_ROOT=/workspaces
NEXO_COREVIEW_DOCKER_HOST=
# Leave empty for auto-detect, or set explicitly:
#   Linux:              unix:///var/run/docker.sock
#   macOS Docker:       unix://$HOME/.docker/run/docker.sock
#   Windows:            npipe:////./pipe/docker_engine
#   Docker Desktop Linux: unix://$HOME/.docker/desktop/docker.sock
# Per-review agent container (OpenCode + MCP). Built automatically on compose up.
NEXO_COREVIEW_AGENT_IMAGE=nexo-coreview-agent:dev
# Required for worker to bind-mount opencode config into spawned agent containers
NEXO_COREVIEW_PROJECT_DIR=/absolute/path/to/code-review
# Docker network for spawned agents (Compose sets coreview).
NEXO_COREVIEW_AGENT_NETWORK=coreview
# Agent HTTP callback (worker injects into spawned containers; api verifies HMAC).
NEXO_COREVIEW_AGENT_CALLBACK_URL=http://localhost:8000/api/v1/agent/review-events
NEXO_COREVIEW_AGENT_CALLBACK_SECRET=dev-callback-secret
NEXO_COREVIEW_OPENCODE_CONFIG_PATH=opencode.generated.json
NEXO_COREVIEW_OPENCODE_SERVER_PASSWORD=
# NEXO_COREVIEW_OPENCODE_SERVER_USERNAME=opencode
# OpenCode internal logs (--print-logs → stderr). Use DEBUG for troubleshooting.
# NEXO_COREVIEW_OPENCODE_LOG_LEVEL=DEBUG

# Kubernetes runtime (stub — not implemented yet)
# NEXO_COREVIEW_RUNTIME_PROVIDER=k8s
# NEXO_COREVIEW_K8S_NAMESPACE=coreview
# NEXO_COREVIEW_K8S_KUBECONFIG_PATH=
# NEXO_COREVIEW_K8S_AGENT_CONFIG_CONFIGMAP=opencode-config
# NEXO_COREVIEW_K8S_IMAGE_PULL_SECRET=

# Optional one-time bootstrap (copied into DB on first load if settings empty)
# NEXO_COREVIEW_GITHUB_WEBHOOK_SECRET=
# NEXO_COREVIEW_GITHUB_TOKEN=
# NEXO_COREVIEW_LLM_BASE_URL=https://api.openai.com/v1
# NEXO_COREVIEW_LLM_API_TOKEN=
# NEXO_COREVIEW_LLM_MODEL=gpt-4o

COGITO_REVIEW_CELERY_BROKER_URL=redis://redis:6379/0

COGITO_REVIEW_RUNTIME_PROVIDER=docker

COGITO_REVIEW_WORKSPACE_ROOT=/workspaces

# Leave empty for auto-detect, or set explicitly:
#   Linux:              unix:///var/run/docker.sock
#   macOS Docker:       unix://$HOME/.docker/run/docker.sock
#   Windows:            npipe:////./pipe/docker_engine
#   Docker Desktop Linux: unix://$HOME/.docker/desktop/docker.sock
# Per-review agent container (OpenCode + MCP). Pulled from GHCR on compose up.
# Worker needs the host Docker socket to spawn review agent containers.
# Set DOCKER_GID on Linux if you run the worker as a non-root user (getent group docker).
# DOCKER_GID=
COGITO_REVIEW_DOCKER_HOST=

# Published images (pin a semver tag or digest in production instead of latest).
COGITO_REVIEW_IMAGE=ghcr.io/cogitoforge-ai/cogito-review:latest
COGITO_REVIEW_AGENT_IMAGE=ghcr.io/cogitoforge-ai/cogito-review-agent:latest

# Agent container caps when worker spawns reviews (t2.medium defaults).
COGITO_REVIEW_AGENT_MEM_LIMIT=1g
COGITO_REVIEW_AGENT_CPUS=1.0

# Docker network for spawned agents (Compose sets coreview).
COGITO_REVIEW_AGENT_NETWORK=coreview

# Agent HTTP callback (worker injects into spawned containers; api verifies HMAC).
COGITO_REVIEW_AGENT_CALLBACK_URL=http://localhost:8000/api/v1/agent/review-events

COGITO_REVIEW_AGENT_CALLBACK_SECRET=dev-callback-secret

# Auth (set COGITO_REVIEW_AUTH_ENABLED=true in production)
COGITO_REVIEW_AUTH_ENABLED=false
COGITO_REVIEW_OIDC_ISSUER=
COGITO_REVIEW_OIDC_CLIENT_ID=
COGITO_REVIEW_OIDC_CLIENT_SECRET=
COGITO_REVIEW_OIDC_REDIRECT_URI=http://localhost:5173/api/v1/auth/callback
COGITO_REVIEW_SESSION_SECRET=change-me-in-production
COGITO_REVIEW_SESSION_TTL_SECONDS=86400
COGITO_REVIEW_BOOTSTRAP_ORG_ADMIN_EMAIL=
COGITO_REVIEW_FRONTEND_URL=http://localhost:5173

COGITO_REVIEW_OPENCODE_LOG_LEVEL=DEBUG

DATABASE_URL=postgresql://app:app@localhost:5432/app?sslmode=disable
POSTGRES_USER=app
POSTGRES_PASSWORD=app
POSTGRES_DB=app
APP_PORT=8000
WEB_PORT=5173
VITE_API_URL=/api/v1
# Vite dev-server proxy (used in docker-compose.dev.yaml)
VITE_API_PROXY_TARGET=http://api:8000
# Set true on Docker Desktop if file watching / HMR is unreliable
CHOKIDAR_USEPOLLING=false
